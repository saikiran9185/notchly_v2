<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sai.notchly</string>

    <key>ProgramArguments</key>
    <array>
        <!-- BUG-34 fix: point to the Release build output, not the old build/ dir -->
        <string>/Applications/Notchly.app/Contents/MacOS/NotchlyV2</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- BUG-35 fix: log dir is created by DirectorySetup.createAll() at launch -->
    <key>StandardOutPath</key>
    <string>/Users/saikiran/notchly/v2/logs/notchly.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/saikiran/notchly/v2/logs/notchly_err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/saikiran</string>
    </dict>
</dict>
</plist>
